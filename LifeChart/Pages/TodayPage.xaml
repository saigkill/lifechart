<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LifeChart.ViewModels"
             x:Class="LifeChart.Pages.TodayPage"
             Title="Heute">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Schnelleingabe -->
            <Label Text="Wie geht es dir heute?"
                   FontSize="20" FontAttributes="Bold" />

            <Label Text="Stimmung" />
            <Slider x:Name="MoodSlider"
                    Minimum="-5" Maximum="5"
                    Value="{Binding MoodValue}"
                    ThumbColor="#0072B2" />
            <Label Text="{Binding MoodValue}"
                   HorizontalTextAlignment="Center" />

            <Label Text="Funktionsfähigkeit" />
            <Slider x:Name="FuncSlider"
                    Minimum="-5" Maximum="5"
                    Value="{Binding FunctionalityValue}"
                    ThumbColor="#E69F00" />
            <Label Text="{Binding FunctionalityValue}"
                   HorizontalTextAlignment="Center" />

            <!-- Mehr-Button -->
            <Button Text="Mehr..."
                    Command="{Binding ToggleFullEntryCommand}"
                    IsVisible="{Binding ShowFullEntry, Converter={StaticResource InvertedBoolConverter}}" />

            <!-- Vollständige Eingabe -->
            <VerticalStackLayout IsVisible="{Binding ShowFullEntry}" Spacing="12">

                <Label Text="Schlafstunden" />
                <Stepper Minimum="0" Maximum="24"
                         Value="{Binding SleepHours}" />
                <Label Text="{Binding SleepHours, StringFormat='{0} Stunden'}"
                       HorizontalTextAlignment="Center" />

                <HorizontalStackLayout Spacing="8">
                    <CheckBox IsChecked="{Binding MedicationTaken}" />
                    <Label Text="Medikamente eingenommen" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="8">
                    <CheckBox IsChecked="{Binding MenstrualCycle}" />
                    <Label Text="Menstruationszyklus" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <Label Text="Symptome (optional)" />
                <Editor Placeholder="Freitext..."
                        Text="{Binding Symptoms}"
                        AutoSize="TextChanges"
                        MaxLength="1000" />

                <Label Text="Notizen (optional)" />
                <Editor Placeholder="Freitext..."
                        Text="{Binding Notes}"
                        AutoSize="TextChanges"
                        MaxLength="2000" />

            </VerticalStackLayout>

            <!-- Speichern -->
            <Button Text="Speichern"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#0072B2"
                    TextColor="White" />

            <Label Text="Eintrag heute bereits gespeichert."
                   IsVisible="{Binding EntryAlreadySaved}"
                   HorizontalTextAlignment="Center"
                   TextColor="Gray" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
