<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dto="clr-namespace:LifeChart.Application.DTOs;assembly=LifeChart.Application"
             x:Class="LifeChart.Pages.CrisisPage"
             Title="Hilfe in der Krise">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <Label Text="Du musst das nicht alleine durchstehen."
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}" />

            <CollectionView ItemsSource="{Binding Resources}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dto:CrisisResourceDto">
                        <Border Margin="0,4" Padding="16" StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding Name}"
                                       FontAttributes="Bold" FontSize="16" />
                                <Label Text="{Binding PhoneNumber}"
                                       FontSize="20" TextColor="#0072B2" />
                                <Label Text="Kostenlos · 24/7"
                                       IsVisible="{Binding IsAvailable24h}"
                                       TextColor="Gray" FontSize="12" />
                                <Button Text="Jetzt anrufen"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CallCommand}"
                                        CommandParameter="{Binding PhoneNumber}"
                                        BackgroundColor="#0072B2"
                                        TextColor="White" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
