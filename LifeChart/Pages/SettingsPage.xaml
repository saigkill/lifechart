<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:settings="clr-namespace:LifeChart.Application.Settings;assembly=LifeChart.Application"
             x:Class="LifeChart.Pages.SettingsPage"
             Title="Einstellungen">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="20">

            <!-- Backup -->
            <Label Text="Backup" FontAttributes="Bold" FontSize="16" />

            <Picker Title="Cloud-Anbieter"
                    ItemsSource="{Binding CloudProviders}"
                    SelectedItem="{Binding BackupProvider}" />

            <VerticalStackLayout IsVisible="{Binding BackupProvider,
                Converter={StaticResource IsNextcloudConverter}}" Spacing="8">
                <Label Text="Nextcloud-URL" />
                <Entry Placeholder="https://cloud.example.com"
                       Text="{Binding NextcloudUrl}"
                       Keyboard="Url" />
            </VerticalStackLayout>

            <HorizontalStackLayout Spacing="8">
                <Switch IsToggled="{Binding AutoBackupEnabled}" />
                <Label Text="Automatisches Backup (täglich)" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="8">
                <Label Text="Warnung nach" VerticalOptions="Center" />
                <Entry Text="{Binding BackupWarningThresholdDays}"
                       Keyboard="Numeric" WidthRequest="60" />
                <Label Text="Tagen ohne Backup (0 = aus)" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" />

            <!-- Erinnerungen -->
            <Label Text="Erinnerungen" FontAttributes="Bold" FontSize="16" />

            <HorizontalStackLayout Spacing="8">
                <Switch IsToggled="{Binding EveningReminderEnabled}" />
                <Label Text="Abend-Erinnerung für Tageseintrag" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="8"
                IsVisible="{Binding EveningReminderEnabled}">
                <Label Text="Uhrzeit:" VerticalOptions="Center" />
                <TimePicker Time="{Binding EveningReminderTime}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="8">
                <Switch IsToggled="{Binding CrisisHintEnabled}" />
                <Label Text="Krisenhinweis bei sehr niedrigen Werten" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" />

            <!-- UX -->
            <Label Text="Darstellung" FontAttributes="Bold" FontSize="16" />

            <Picker Title="Eingabemodus"
                    ItemsSource="{Binding InputModes}"
                    SelectedItem="{Binding InputMode}" />

            <HorizontalStackLayout Spacing="8">
                <Switch IsToggled="{Binding ColorBlindModeEnabled}" />
                <Label Text="Farbenblind-Modus (Wong-Palette)" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" />

            <!-- App -->
            <Label Text="App" FontAttributes="Bold" FontSize="16" />

            <HorizontalStackLayout Spacing="8">
                <Switch IsToggled="{Binding BiometricsEnabled}" />
                <Label Text="Biometrie (Fingerabdruck)" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Picker Title="Sprache"
                    ItemsSource="{Binding Languages}"
                    SelectedItem="{Binding Language}" />

            <Button Text="Einstellungen speichern"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#0072B2"
                    TextColor="White" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
