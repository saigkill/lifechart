<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dto="clr-namespace:LifeChart.Application.DTOs;assembly=LifeChart.Application"
             x:Class="LifeChart.Pages.MedicationsPage"
             xmlns:loc="clr-namespace:LifeChart.Application.Localization;assembly=LifeChart.Application"
             Title="{x:Static loc:L.Medications_Title}">

    <Grid RowDefinitions="*,Auto" Padding="16" RowSpacing="12">

        <CollectionView Grid.Row="0" ItemsSource="{Binding Medications}">
            <CollectionView.EmptyView>
                <Label Text="{x:Static loc:L.Medications_Empty}"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       Style="{StaticResource SecondaryLabelStyle}" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:MedicationDto">
                    <Border Style="{StaticResource CardStyle}">
                        <Grid ColumnDefinitions="*,Auto,Auto">

                            <!-- Info -->
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding Name}"
                                       FontAttributes="Bold" FontSize="15" />
                                <Label Text="{Binding Dosage}"
                                       Style="{StaticResource SecondaryLabelStyle}" />
                                <Label Text="{Binding CurrentStock, StringFormat='Bestand: {0}'}"
                                       TextColor="{Binding IsStockLow,
                                           Converter={StaticResource StockColorConverter}}"
                                       FontSize="12" />
                            </VerticalStackLayout>

                            <!-- Bearbeiten -->
                            <Button Grid.Column="1"
                                    Text="✏"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource Primary}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                        Path=BindingContext.EditCommand}"
                                    CommandParameter="{Binding .}"
                                    WidthRequest="44" Padding="0" />

                            <!-- Entfernen -->
                            <Button Grid.Column="2"
                                    Text="✕"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                        Path=BindingContext.DeleteCommand}"
                                    CommandParameter="{Binding .}"
                                    WidthRequest="44" Padding="0" />

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="1"
                Text="{x:Static loc:L.Medications_AddTitle}"
                Command="{Binding AddCommand}"
                Style="{StaticResource PrimaryButtonStyle}" />

    </Grid>

</ContentPage>
