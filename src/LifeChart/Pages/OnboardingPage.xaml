<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LifeChart.Pages.OnboardingPage"
             xmlns:loc="clr-namespace:LifeChart.Application.Localization;assembly=LifeChart.Application"
             Title="{x:Static loc:L.Onboarding_Title}"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20" VerticalOptions="Center">

            <Label Text="{x:Static loc:L.Onboarding_Welcome}"
                   FontSize="24" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />

            <Label Text="{x:Static loc:L.Onboarding_Subtitle}"
                   HorizontalTextAlignment="Center"
                   TextColor="Gray" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <!-- Disclaimer -->
            <Border Padding="16" BackgroundColor="#FFF8E1" StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{x:Static loc:L.Onboarding_DisclaimerTitle}" FontAttributes="Bold" />
                    <Label Text="{x:Static loc:L.Onboarding_Disclaimer}"
                           FontSize="13" />
                    <Label Text="{x:Static loc:L.Onboarding_CrisisHotline}"
                           FontSize="13" FontAttributes="Bold" TextColor="#0072B2" />
                </VerticalStackLayout>
            </Border>

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <!-- Abend-Erinnerung -->
            <Label Text="{x:Static loc:L.Onboarding_ReminderQuestion}"
                   FontAttributes="Bold" />

            <HorizontalStackLayout Spacing="8">
                <Switch IsToggled="{Binding ReminderEnabled}" />
                <Label Text="{x:Static loc:L.Settings_EveningReminderEnable}" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="8"
                IsVisible="{Binding ReminderEnabled}">
                <Label Text="{x:Static loc:L.Common_Time}" VerticalOptions="Center" />
                <TimePicker Time="{Binding ReminderTime}" />
            </HorizontalStackLayout>

            <Button Text="{x:Static loc:L.Onboarding_Start}"
                    Command="{Binding CompleteCommand}"
                    BackgroundColor="#0072B2"
                    TextColor="White"
                    Margin="0,16,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
