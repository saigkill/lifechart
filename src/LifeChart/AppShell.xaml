<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:LifeChart.Pages"
       xmlns:loc="clr-namespace:LifeChart.Application.Localization;assembly=LifeChart.Application"
       x:Class="LifeChart.AppShell">

    <TabBar>
        <ShellContent Title="{x:Static loc:L.Today_Title}"
                      Icon="tab_today.png"
                      ContentTemplate="{DataTemplate pages:TodayPage}"
                      Route="TodayPage" />

        <ShellContent Title="{x:Static loc:L.Chart_Title}"
                      Icon="tab_chart.png"
                      ContentTemplate="{DataTemplate pages:ChartPage}"
                      Route="ChartPage" />

        <ShellContent Title="{x:Static loc:L.Medications_Title}"
                      Icon="tab_medications.png"
                      ContentTemplate="{DataTemplate pages:MedicationsPage}"
                      Route="MedicationsPage" />

        <ShellContent Title="{x:Static loc:L.About_Title}"
                      ContentTemplate="{DataTemplate pages:AboutPage}"
                      Route="AboutPage" />
    </TabBar>

    <Shell.FlyoutFooter>
        <VerticalStackLayout Padding="16" Spacing="8">
            <Button Text="{x:Static loc:L.Settings_Title}"
                    Command="{Binding Source={RelativeSource Self},
                        Path=BindingContext.NavigateToSettingsCommand}" />
            <Button Text="🆘 Krisentelefon"
                    TextColor="#CC0000"
                    BackgroundColor="Transparent"
                    Command="{Binding Source={RelativeSource Self},
                        Path=BindingContext.NavigateToCrisisCommand}" />
        </VerticalStackLayout>
    </Shell.FlyoutFooter>

</Shell>
