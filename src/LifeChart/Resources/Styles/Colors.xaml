<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Wong palette — farbenblindfreundlich -->
    <Color x:Key="MoodColor">#0072B2</Color>
    <Color x:Key="FunctionalityColor">#E69F00</Color>

    <!-- App-Farben -->
    <Color x:Key="Primary">#0072B2</Color>
    <Color x:Key="PrimaryDark">#005a8e</Color>
    <Color x:Key="Secondary">#E69F00</Color>
    <Color x:Key="Danger">#CC0000</Color>
    <Color x:Key="Success">#009E73</Color>
    <Color x:Key="Warning">#F0E442</Color>

    <!-- Neutrale Farben -->
    <Color x:Key="TextPrimary">#1A1A1A</Color>
    <Color x:Key="TextSecondary">#6B6B6B</Color>
    <Color x:Key="Background">#FFFFFF</Color>
    <Color x:Key="SurfaceBackground">#F5F5F5</Color>
    <Color x:Key="Separator">#E0E0E0</Color>

    <!-- Krisenfarbe -->
    <Color x:Key="CrisisRed">#CC0000</Color>

</ResourceDictionary>
