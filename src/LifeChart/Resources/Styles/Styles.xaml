<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Primary Button -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <!-- Danger Button -->
    <Style x:Key="DangerButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Danger}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <!-- Crisis Button -->
    <Style x:Key="CrisisButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource CrisisRed}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <!-- Section Header -->
    <Style x:Key="SectionHeaderStyle" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="Margin" Value="0,8,0,4" />
    </Style>

    <!-- Body Label -->
    <Style x:Key="BodyLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <!-- Secondary Label -->
    <Style x:Key="SecondaryLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <!-- Card Border -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Background}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 8" />
        <Setter Property="Stroke" Value="{StaticResource Separator}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="0,4" />
    </Style>

    <!-- Disclaimer Card -->
    <Style x:Key="DisclaimerCardStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="#FFF8E1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 8" />
        <Setter Property="Stroke" Value="{StaticResource Warning}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="0,4" />
    </Style>

</ResourceDictionary>
