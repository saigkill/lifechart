<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LifeChart.Linux.Pages.CrisisPage">
    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="24,16">

            <Label x:Name="NotAloneLabel"
                   FontSize="18" FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   HorizontalOptions="Center"/>

            <HorizontalStackLayout Spacing="12">
                <Label x:Name="RegionLabel" VerticalOptions="Center"/>
                <Picker x:Name="RegionPicker"
                        HorizontalOptions="FillAndExpand"
                        SelectedIndexChanged="OnRegionPickerChanged"/>
            </HorizontalStackLayout>

            <ActivityIndicator x:Name="Spinner"
                               IsRunning="False" IsVisible="False"
                               HorizontalOptions="Center"/>

            <Label x:Name="ErrorLabel"
                   TextColor="Red"
                   HorizontalOptions="Center"
                   IsVisible="False"/>

            <VerticalStackLayout x:Name="ResourcesLayout" Spacing="10"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
