<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LifeChart.Linux.Pages.OnboardingPage">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20" VerticalOptions="Center">

            <Label x:Name="WelcomeLabel"
                   FontSize="24" FontAttributes="Bold"
                   HorizontalTextAlignment="Center"/>

            <Label x:Name="SubtitleLabel"
                   HorizontalTextAlignment="Center"
                   TextColor="Gray"/>

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8"/>

            <!-- Disclaimer box -->
            <Border Padding="16" BackgroundColor="#FFF8E1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="DisclaimerTitleLabel" FontAttributes="Bold"/>
                    <Label x:Name="DisclaimerLabel" FontSize="13"/>
                    <Label x:Name="CrisisHotlineLabel"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="#0072B2"/>
                </VerticalStackLayout>
            </Border>

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8"/>

            <Label x:Name="ReminderQuestionLabel" FontAttributes="Bold"/>

            <HorizontalStackLayout Spacing="8">
                <Switch x:Name="ReminderSwitch" IsToggled="True" Toggled="OnReminderSwitchToggled"/>
                <Label x:Name="ReminderEnableLabel" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout x:Name="TimeRow" Spacing="8">
                <Label x:Name="TimeLabel" VerticalOptions="Center"/>
                <TimePicker x:Name="ReminderTimePicker" Time="20:00:00"/>
            </HorizontalStackLayout>

            <Label x:Name="ReminderNoteLabel"
                   FontSize="11" TextColor="Gray" FontAttributes="Italic"/>

            <Button x:Name="CompleteButton"
                    BackgroundColor="#0072B2" TextColor="White"
                    HorizontalOptions="Fill"
                    Margin="0,16,0,0"
                    Clicked="OnCompleteClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
