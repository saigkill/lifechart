{
  "id": "com.github.saigkill.lifechart",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.dotnet10"
  ],
  "command": "lifechart",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=xdg-data/lifechart:create",
    "--talk-name=org.freedesktop.Notifications"
  ],
  "cleanup": [
    "/include", "/lib/pkgconfig", "/man",
    "/share/doc", "/share/gtk-doc", "/share/man",
    "/share/pkgconfig", "/share/vala",
    "*.la", "*.a"
  ],
  "modules": [
    {
      "name": "lifechart",
      "builddir": true,
      "buildsystem": "simple",
      "build-options": {
        "append-path": "/usr/lib/sdk/dotnet10/bin",
        "append-ld-library-path": "/usr/lib/sdk/dotnet10/lib",
        "prepend-pkg-config-path": "/usr/lib/sdk/dotnet10/lib/pkgconfig",
        "env": {
          "DOTNET_CLI_TELEMETRY_OPTOUT": "true",
          "DOTNET_SKIP_FIRST_TIME_EXPERIENCE": "true",
          "HOME": "/run/build/lifechart"
        }
      },
      "build-commands": [
        "dotnet publish src/LifeChart.Linux/LifeChart.Linux.csproj -c Release -r linux-x64 --self-contained true --source ./nuget-sources --source /usr/lib/sdk/dotnet10/nuget/packages /p:MSBuildEnableWorkloadResolver=false -o /run/build/lifechart/publish",
        "cp -r /run/build/lifechart/publish/. /app/bin/",
        "install -Dm755 /app/bin/LifeChart.Linux /app/bin/lifechart",
        "install -Dm644 Assets/com.github.saigkill.LifeChart.png /app/share/icons/hicolor/256x256/apps/com.github.saigkill.lifechart.png",
        "install -Dm644 Assets/com.github.saigkill.LifeChart.svg /app/share/icons/hicolor/scalable/apps/com.github.saigkill.lifechart.svg",
        "install -Dm644 Assets/com.github.saigkill.lifechart.metainfo.xml /app/share/metainfo/com.github.saigkill.lifechart.metainfo.xml",
        "install -Dm644 Assets/com.github.saigkill.lifechart.desktop /app/share/applications/com.github.saigkill.lifechart.desktop"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/saigkill/lifechart",
          "branch": "main"
        },
        "sources.json",
        {
          "type": "file",
          "path": "src/Directory.Build.props.user",
          "dest": "src"
        }
      ]
    }
  ]
}
